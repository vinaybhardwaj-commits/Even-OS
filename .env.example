# Even OS Environment Configuration
# Copy to .env.local and fill in values

# === REQUIRED ===

# PostgreSQL connection (Neon for dev/staging, Azure for production)
DATABASE_URL=postgresql://user:password@host:5432/even_os

# JWT secret for authentication (minimum 32 characters)
JWT_SECRET=your-32-character-minimum-secret-here

# Encryption key for sensitive data (exactly 32 characters)
ENCRYPTION_KEY=your-32-character-encryption-key

# === OPTIONAL (dev defaults work) ===

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Email (Resend — needed for password reset)
RESEND_API_KEY=re_test_xxxxx

# LLM (Azure OpenAI — needed for AI features)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# Ollama fallback (local Mac Mini)
OLLAMA_BASE_URL=http://localhost:11434

# Storage (Vercel Blob for dev, Azure Blob for production)
BLOB_READ_WRITE_TOKEN=
