# Test environment overrides — copy to .env.test for local test runs.
# Never commit .env.test (it's gitignored).

# Test database — IMPORTANT: must NOT be the prod database.
# Use a Neon ephemeral branch URL or a dedicated test database.
TEST_DATABASE_URL=postgresql://USER:PASS@HOST/even_os_test?sslmode=require

# Neon API key — required for CI ephemeral branch creation. Get from
# https://console.neon.tech/app/settings/api-keys
NEON_API_KEY=

# Playwright e2e target. Defaults to http://localhost:3000.
# In CI: set to your Vercel preview URL or staging URL.
TEST_E2E_BASE_URL=http://localhost:3000

# Re-declared here so tests don't accidentally use prod values
JWT_SECRET=test-jwt-secret-only-for-tests
ENCRYPTION_KEY=test-encryption-key-32-bytes-x
