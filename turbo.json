{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env.*local"
  ],
  "globalEnv": [
    "DATABASE_URL",
    "JWT_SECRET",
    "ENCRYPTION_KEY",
    "LSQ_ACCESS_KEY",
    "LSQ_SECRET_KEY",
    "LSQ_API_HOST",
    "NEXT_PUBLIC_APP_URL",
    "NODE_ENV",
    "NEON_API_KEY",
    "TEST_DATABASE_URL",
    "CI"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": [
        "^build"
      ]
    },
    "test": {
      "dependsOn": [],
      "outputs": [
        "coverage/**"
      ],
      "env": [
        "DATABASE_URL",
        "TEST_DATABASE_URL",
        "NEON_API_KEY"
      ]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:coverage": {
      "dependsOn": [],
      "outputs": [
        "coverage/**"
      ]
    },
    "test:e2e": {
      "dependsOn": [],
      "outputs": [
        "playwright-report/**",
        "test-results/**"
      ],
      "env": [
        "NEXT_PUBLIC_APP_URL",
        "TEST_E2E_BASE_URL"
      ]
    }
  }
}
